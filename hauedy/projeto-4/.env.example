# Chave da API OpenAI (obrigatória)
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-sua-chave-aqui

# Modelo LLM (opcional — padrão: gpt-4o-mini)
LLM_MODEL=gpt-4o-mini

# Temperatura do LLM (0.0 = determinístico, ideal para extração de dados)
LLM_TEMPERATURE=0.0

# Intervalo de coleta automática em horas (padrão: 24h = 1x ao dia)
SCRAPING_INTERVAL_HOURS=24
